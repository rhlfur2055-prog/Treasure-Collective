{
  // 보물모아 웹사이트 — Cloudflare Worker (정적 자산 + API)
  "name": "bomulmoa",
  "main": "worker.js",
  "compatibility_date": "2026-07-01",
  "workers_dev": true,
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },
  "routes": [
    { "pattern": "bomulmoa.com", "custom_domain": true }
  ]
}
